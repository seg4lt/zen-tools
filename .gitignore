# Rust / Tauri
target/
src-tauri/target/
src-tauri/gen/schemas
**/Cargo.lock.bak
.tauri

# Dictation: Whisper ggml model weights are downloaded on demand into
# the user's app-data dir at runtime. If anyone ever stages a `models/`
# folder under the repo (e.g. while debugging), make sure the
# multi-hundred-MB binaries don't sneak into a commit.
**/models/ggml-*.bin
**/models/ggml-*.bin.tmp

# Whisper.cpp Metal shader build artefacts. We embed the .metal source
# into the static library at build time via `GGML_METAL_EMBED_LIBRARY`
# (see `crates/zen-whisper/build.rs`), so these only ever appear if
# someone runs `xcrun -sdk macosx metal` by hand for debugging.
*.metallib
*.air

# macOS debug symbols produced by `cargo build --release` with split
# debug info. Not part of the source tree.
*.dSYM/

# zen-test-server has its own [workspace] (see top-level Cargo.toml
# `exclude`), so cargo creates a sibling target dir here too.
crates/zen-test-server/target/

# Ghostty / Zig build cache. `vendor/ghostty/` is a git submodule
# pinned to a clean upstream tag (currently v1.3.1); our local
# build/SDK plumbing fixes live as ordered patch files under
# `patches/ghostty/*.patch` and are applied to the submodule working
# tree by `crates/ghostty-sys/build.rs::apply_patches` before invoking
# zig (idempotent — uses `git apply -R --check` to detect already-
# applied patches and no-op).
#
# These ignores cover the .zig-cache / .zig-out the Zig build drops
# inside the submodule's working tree on every cargo build. The
# submodule has its own `.gitignore` that mostly handles this, but
# adding belt-and-suspenders here means a stray `git status` from the
# submodule never leaks build artefacts up to the parent repo's
# tracked changes.
vendor/ghostty/.zig-cache/
vendor/ghostty/zig-cache/
vendor/ghostty/zig-out/

# Env & secrets
.env
.env.local
.env.*.local

