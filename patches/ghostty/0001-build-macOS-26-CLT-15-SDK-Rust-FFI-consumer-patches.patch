From 36f913b6a5b17b1f9e7ea322990c431384e1895c Mon Sep 17 00:00:00 2001
From: seg4lt <12027886+seg4lt@users.noreply.github.com>
Date: Sun, 3 May 2026 15:30:01 -0500
Subject: [PATCH] build: macOS-26 + CLT-15-SDK + Rust-FFI consumer patches
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Three patches required to build libghostty.a as a static lib that a
Rust FFI consumer can link against on a macOS 26 host using Zig
0.15.2 + the Command Line Tools' MacOSX15.sdk:

* build.zig: drop the `isDarwin()` guard around `libghostty_static.install("libghostty.a")` so the static lib actually installs on macOS (upstream comment on the same lines acknowledges the guard is wrong). Also gate the macOS xcframework / app init on emit_xcframework or emit_macos_app being requested — otherwise `GhosttyXCFramework.init` runs unconditionally and tries to build the iOS lib, which needs an iOS SDK we don't have under DEVELOPER_DIR=CLT.

* pkg/apple-sdk/build.zig: honor GHOSTTY_SDK_PATH env var as an override that bypasses `std.zig.LibCInstallation.findNative` (which calls xcrun and ignores SDKROOT for `--sdk macosx`). Necessary because Zig 0.15.2 cannot parse the libSystem.tbd format in MacOSX26.x.sdk; we point it at MacOSX15.sdk explicitly.

* src/build/MetallibStep.zig: use `xcrun` from PATH instead of the hard-coded `/usr/bin/xcrun`. With our wrapper xcrun shim early in PATH (handles the `--sdk macosx --show-sdk-path` override AND forwards the `metal` tool to Xcode's Metal toolchain when DEVELOPER_DIR=CLT), the Metal shader compile step works.

These three patches are NOT specific to libghostty's terminal logic — they're purely build/SDK plumbing for unusual host environments. PageList.zig and page.zig modifications already in the worktree are deliberately not included; those are separate work.
---
 build.zig                  | 28 ++++++++++++++++++++--------
 pkg/apple-sdk/build.zig    | 20 ++++++++++++++++----
 src/build/MetallibStep.zig |  4 ++--
 3 files changed, 38 insertions(+), 14 deletions(-)

diff --git a/build.zig b/build.zig
index f9d861b19..754546f9a 100644
--- a/build.zig
+++ b/build.zig
@@ -136,18 +136,28 @@ pub fn build(b: *std.Build) !void {
         // As such, these build steps are lacking. For example, the Darwin
         // build only produces an xcframework.
 
-        // We shouldn't have this guard but we don't currently
-        // build on macOS this way ironically so we need to fix that.
+        // PATCH (tauri-terminal): the upstream isDarwin guard skipped
+        // libghostty.{a,so} install on macOS because upstream only ships
+        // an xcframework there. We embed via FFI, so we always need the
+        // static lib. Drop the guard so install() runs unconditionally.
+        // Upstream comment: "We shouldn't have this guard but we don't
+        // currently build on macOS this way ironically so we need to fix
+        // that." -- this patch is the fix for our use.
+        libghostty_shared.installHeader(); // Only need one header
+        libghostty_static.install("libghostty.a");
         if (!config.target.result.os.tag.isDarwin()) {
-            libghostty_shared.installHeader(); // Only need one header
             libghostty_shared.install("libghostty.so");
-            libghostty_static.install("libghostty.a");
         }
     }
 
     // macOS only artifacts. These will error if they're initialized for
     // other targets.
-    if (config.target.result.os.tag.isDarwin()) {
+    //
+    // PATCH (tauri-terminal): only init the xcframework / macOS app when
+    // they will actually be emitted. Init for ios target requires an iOS
+    // SDK we don't have on this CLT-only setup. The user is building
+    // libghostty.a only.
+    if (config.target.result.os.tag.isDarwin() and (config.emit_xcframework or config.emit_macos_app)) {
         // Ghostty xcframework
         const xcframework = try buildpkg.GhosttyXCFramework.init(
             b,
@@ -200,9 +210,11 @@ pub fn build(b: *std.Build) !void {
 
         assert(config.app_runtime == .none);
 
-        // On macOS we can run the macOS app. For "run" we always force
-        // a native-only build so that we can run as quickly as possible.
-        if (config.target.result.os.tag.isDarwin()) {
+        // PATCH (tauri-terminal): skip macOS run-step xcframework setup
+        // unless we're actually emitting the macOS app. The xcframework
+        // init unconditionally builds an iOS lib which we don't have an
+        // SDK for in our CLT-only setup.
+        if (false and config.target.result.os.tag.isDarwin()) {
             const xcframework_native = try buildpkg.GhosttyXCFramework.init(
                 b,
                 &deps,
diff --git a/pkg/apple-sdk/build.zig b/pkg/apple-sdk/build.zig
index c573c3910..bdeda6a2b 100644
--- a/pkg/apple-sdk/build.zig
+++ b/pkg/apple-sdk/build.zig
@@ -41,10 +41,22 @@ pub fn addPaths(
     });
 
     if (!gop.found_existing) {
-        // Detect our SDK using the "findNative" Zig stdlib function.
-        // This is really important because it forces using `xcrun` to
-        // find the SDK path.
-        const libc = try std.zig.LibCInstallation.findNative(.{
+        // PATCH (tauri-terminal): On macOS 26 hosts, `xcrun --sdk macosx`
+        // ignores SDKROOT and always returns the default (MacOSX26.x.sdk),
+        // whose libSystem.tbd format Zig 0.15.2 cannot parse. Honor a
+        // GHOSTTY_SDK_PATH env override to force a specific SDK (e.g.
+        // /Library/Developer/CommandLineTools/SDKs/MacOSX15.sdk). When
+        // set, we synthesize the LibCInstallation manually rather than
+        // calling findNative.
+        const libc = if (std.posix.getenv("GHOSTTY_SDK_PATH")) |sdk_path| blk: {
+            const sys_include = try std.fs.path.join(b.allocator, &.{
+                sdk_path, "usr", "include",
+            });
+            break :blk std.zig.LibCInstallation{
+                .include_dir = sys_include,
+                .sys_include_dir = sys_include,
+            };
+        } else try std.zig.LibCInstallation.findNative(.{
             .allocator = b.allocator,
             .target = &step.rootModuleTarget(),
             .verbose = false,
diff --git a/src/build/MetallibStep.zig b/src/build/MetallibStep.zig
index fcf3055f8..a221b9137 100644
--- a/src/build/MetallibStep.zig
+++ b/src/build/MetallibStep.zig
@@ -55,7 +55,7 @@ pub fn create(b: *std.Build, opts: Options) ?*MetallibStep {
         b,
         b.fmt("metal {s}", .{opts.name}),
     );
-    run_ir.addArgs(&.{ "/usr/bin/xcrun", "-sdk", sdk, "metal", "-o" });
+    run_ir.addArgs(&.{ "xcrun", "-sdk", sdk, "metal", "-o" });
     const output_ir = run_ir.addOutputFileArg(b.fmt("{s}.ir", .{opts.name}));
     run_ir.addArgs(&.{"-c"});
     for (opts.sources) |source| run_ir.addFileArg(source);
@@ -70,7 +70,7 @@ pub fn create(b: *std.Build, opts: Options) ?*MetallibStep {
         b,
         b.fmt("metallib {s}", .{opts.name}),
     );
-    run_lib.addArgs(&.{ "/usr/bin/xcrun", "-sdk", sdk, "metallib", "-o" });
+    run_lib.addArgs(&.{ "xcrun", "-sdk", sdk, "metallib", "-o" });
     const output_lib = run_lib.addOutputFileArg(b.fmt("{s}.metallib", .{opts.name}));
     run_lib.addFileArg(output_ir);
     run_lib.step.dependOn(&run_ir.step);
