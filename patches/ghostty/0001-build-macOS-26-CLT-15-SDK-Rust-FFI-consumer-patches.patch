+    // PATCH (tauri-terminal): In Zig 0.15.x lazy-analysis builds, functions
+    // inside a struct are NOT emitted into the archive unless @export is
+    // called. We use `pub fn ... callconv(.c)` (no `export` keyword) to
+    // avoid "exported symbol collision", then drive symbol emission via
+    // @export here. The function pointer (&@field) is required by Zig 0.15.x;
+    // passing a fn value (without &) triggers "expected pointer type" error.
+    if (@hasDecl(apprt.runtime, "CAPI")) {
+        const CAPI = apprt.runtime.CAPI;
+        for (std.meta.declarations(CAPI)) |decl| {
+            switch (@typeInfo(@TypeOf(@field(CAPI, decl.name)))) {
+                .@"fn" => @export(&@field(CAPI, decl.name), .{ .name = decl.name }),
+                else => {},
+            }
+        }
+    }
 
