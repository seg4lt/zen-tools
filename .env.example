# Apple Silicon users: copy this file to .env before running `docker compose up`.
# The default mssql/server:2022-latest image is amd64-only and will not run
# natively on arm64. azure-sql-edge is a multi-arch superset of SQL Server 2019
# that speaks the same TDS protocol, so tiberius / sqlcmd connect identically.

MSSQL_IMAGE=mcr.microsoft.com/azure-sql-edge:latest
DOCKER_PLATFORM=linux/arm64/v8
